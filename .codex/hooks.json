{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'codegraph sync'",
            "timeout": 300,
            "statusMessage": "Running codegraph sync"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/mac-popup.js",
            "statusMessage": "完了ポップアップを表示中..."
          }
        ]
      }
    ]
  }
}
